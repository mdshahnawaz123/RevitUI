<Window x:Class="RevitUI.UI.MasterOpening"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Digital Design"
        Height="450" Width="500">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Border Style="{StaticResource Card}">
            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Master Opening"
                           Style="{StaticResource TitleText}"/>

                <!-- FLOATING INPUT -->
                <Grid Margin="5">
                    <TextBox x:Name="txtName"
                             Style="{StaticResource ModernTextBox}"
                             Height="35"/>

                    <TextBlock Text="Opening Name"
                               Foreground="Gray"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="">
                                        <Setter Property="FontSize" Value="13"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="{x:Null}">
                                        <Setter Property="FontSize" Value="13"/>
                                    </DataTrigger>

                                    <!-- When typing -->
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=txtName}" Value="1">
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Margin" Value="10,-10,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

                    </TextBlock>
                </Grid>

                <!-- ICON BUTTON -->
                <Button Style="{StaticResource IconButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧱" Margin="0,0,6,0"/>
                        <TextBlock Text="Create Opening"/>
                    </StackPanel>
                </Button>

                <!-- DARK MODE -->
                <ToggleButton Content="🌙 Dark Mode"
                              Margin="5"
                              Checked="DarkMode_On"
                              Unchecked="DarkMode_Off"/>

            </StackPanel>
        </Border>
    </Grid>

</Window>