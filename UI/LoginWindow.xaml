<Window x:Class="RevitUI.UI.LoginWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:local="clr-namespace:RevitUI.UI"
             Height="320" Width="400" 
             Title="BIM Digital Design" 
             Icon="{x:Null}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="16"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Username -->
            <RowDefinition Height="10"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Password -->
            <RowDefinition Height="10"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Error label -->
            <RowDefinition Height="*"/>
            <!-- Push buttons down -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
               Text="BIM Digital Design"
               FontSize="18"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"/>

        <!-- Username -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Username" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="TB_Username"
                 Height="34"
                 Padding="8,6"
                 FontSize="13"/>
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Password" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PB_Password"
                     Height="34"
                     Padding="8,6"
                     FontSize="13"/>
        </StackPanel>

        <!-- Error / Status message -->
        <TextBlock x:Name="TB_Error"
               Grid.Row="6"
               FontSize="12"
               Foreground="Red"
               TextWrapping="Wrap"
               MinHeight="18"
               Margin="0,4,0,0"/>

        <!-- Buttons -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                Content="Cancel"
                Height="36"
                Click="Cancel_Click"/>

            <Button Grid.Column="2"
                Content="Sign In"
                Height="36"
                IsDefault="True"
                Click="SignIn_Click"/>
        </Grid>
    </Grid>
</Window>
